# Required
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/diary_study?sslmode=verify-full"
SESSION_SECRET="replace-with-openssl-rand-base64-32"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Recommended for production
APP_URL=""
CRON_SECRET="replace-with-another-long-random-secret"
RESEND_API_KEY=""
EMAIL_FROM="diARI <research@example.com>"
BLOB_READ_WRITE_TOKEN=""

# AI-assisted analysis
# Default provider is Anthropic. Participant answers may be sent to this provider
# when researchers use AI tagging/grouping features.
AI_PROVIDER="anthropic"
ANTHROPIC_API_KEY=""

# Optional local AI provider for development.
# AI_PROVIDER="ollama"
OLLAMA_BASE_URL="http://localhost:11434/v1"
OLLAMA_MODEL="qwen2.5"

# QA and smoke checks
QA_BASE_URL="http://localhost:3000"
SMOKE_BASE_URL="http://localhost:3000"
SMOKE_INVITE_URL=""
QA_PARTICIPANT_EMAIL="qa.participant@diari.test"
QA_PARTICIPANT_PASSWORD="qa-participant-123"
